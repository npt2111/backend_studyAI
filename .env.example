SECRET_KEY=replace-with-a-long-random-secret
DEBUG=true
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
JWT_SECRET=replace-with-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=10080
REFRESH_TOKEN_DAYS=30

# Example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# AI summarize worker
SUPABASE_STORAGE_BUCKET=study-documents
SUMMARY_MAX_FILE_MB=20
SUMMARY_USE_INLINE_WORKER=false
SUMMARY_CHUNK_CHARS=2500
SUMMARY_CHUNK_MAX_TOKENS=300
SUMMARY_FINAL_MAX_TOKENS=700
SUMMARY_WORKER_THREADS=1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT_SECONDS=180
EASYOCR_ENABLED=true
EASYOCR_LANGS=vi,en
EASYOCR_GPU=false
EASYOCR_DPI=130
EASYOCR_MAX_IMAGE_SIDE=1800
EASYOCR_PARAGRAPH=false
PDFPLUMBER_TEXT_MIN_WORDS_PER_PAGE=20
PDF_OCR_MAX_PAGES=0
