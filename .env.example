SECRET_KEY=replace-with-a-long-random-secret
DEBUG=true
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
JWT_SECRET=replace-with-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=10080
REFRESH_TOKEN_DAYS=30

# Example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# AI summarize worker
SUPABASE_STORAGE_BUCKET=study-documents
SUMMARY_MAX_FILE_MB=20
SUMMARY_USE_INLINE_WORKER=false
SUMMARY_CHUNK_CHARS=2500
SUMMARY_CHUNK_MAX_TOKENS=450
SUMMARY_FINAL_MAX_TOKENS=1000
SUMMARY_LLM_INPUT_CHARS=14000
SUMMARY_PRESELECT_SENTENCES=80
SUMMARY_WORKER_THREADS=1
EASYOCR_ENABLED=true
EASYOCR_LANGS=vi,en
EASYOCR_GPU=false
EASYOCR_DPI=130
EASYOCR_MAX_IMAGE_SIDE=1800
EASYOCR_PARAGRAPH=false
PDFPLUMBER_TEXT_MIN_WORDS_PER_PAGE=20
PDF_OCR_MAX_PAGES=0

# AI providers
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GROQ_API_KEY=
GROQ_API_KEY_2=
CHAT_GROQ_API_KEY=
CHAT_GROQ_MODEL=llama-3.3-70b-versatile
CHAT_GROQ_TIMEOUT_SECONDS=120
CHAT_SOURCE_MAX_CHARS=30000
CHAT_CONTEXT_MAX_CHARS=26000
CHAT_CONTEXT_CHUNK_MAX_CHARS=3500
CHAT_RAG_MATCH_LIMIT=8
CHAT_RAG_MATCH_THRESHOLD=0.0
QUIZ_MAX_OUTPUT_TOKENS=10000
FLASHCARD_MAX_OUTPUT_TOKENS=9000
AI_GENERATION_BATCH_SIZE=10
